should escape dollar signs in user-supplied values:
  1: |
    config.yaml.tpl: |
      server:
        listenAddress: ":80${DOLLAR}test"
        exposedAddress: ""
        stunPorts:
          - 3478
        metricsPort: 9090
        healthcheckAddress: ":9000"
        logLevel: "info"
        logFile: "console"

        authSecret: "${AUTH_SECRET}"
        dataDir: "/var/lib/netbird"

        auth:
          issuer: ""
          signKeyRefreshEnabled: true
          cliRedirectURIs:
            - "http://localhost:53000/"

        store:
          engine: "sqlite"
          dsn: ""
          encryptionKey: "${ENCRYPTION_KEY}"
should include seed.yaml for postgresql:
  1: |
    config.yaml.tpl: |
      server:
        listenAddress: ":80"
        exposedAddress: ""
        stunPorts:
          - 3478
        metricsPort: 9090
        healthcheckAddress: ":9000"
        logLevel: "info"
        logFile: "console"

        authSecret: "${AUTH_SECRET}"
        dataDir: "/var/lib/netbird"

        auth:
          issuer: ""
          signKeyRefreshEnabled: true
          cliRedirectURIs:
            - "http://localhost:53000/"

        store:
          engine: "postgres"
          dsn: "host=pg.example.com user=netbird password=${DB_PASSWORD} dbname=netbird port=5432 sslmode=disable"
          encryptionKey: "${ENCRYPTION_KEY}"
    seed.yaml: |
      database:
        driver: postgres
        url: "postgres://netbird:{{ env.DB_PASSWORD }}@pg.example.com:5432/?sslmode=disable"
      phases:
        - name: create-database
          database: netbird
          create_if_missing: true
