should render postgres engine with DSN placeholder:
  1: |
    config.yaml.tpl: |
      server:
        listenAddress: ":80"
        exposedAddress: ""
        stunPorts:
          - 3478
        metricsPort: 9090
        healthcheckAddress: ":9000"
        logLevel: "info"
        logFile: "console"

        authSecret: "${AUTH_SECRET}"
        dataDir: "/var/lib/netbird"

        auth:
          issuer: ""
          signKeyRefreshEnabled: true
          cliRedirectURIs:
            - "http://localhost:53000/"

        store:
          engine: "postgres"
          dsn: "${STORE_DSN}"
          encryptionKey: "${ENCRYPTION_KEY}"
